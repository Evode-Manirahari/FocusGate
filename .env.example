# --- FocusGate environment ---
# Copy to .env and fill in. Never commit .env.

# Server
PORT=3000
# In production, set to "production" so Twilio webhook signatures are verified.
NODE_ENV=development

# Anthropic (work-message triage)
ANTHROPIC_API_KEY=sk-ant-...
# Fast, cheap classifier model. Triage is high-volume + latency-sensitive.
TRIAGE_MODEL=claude-haiku-4-5-20251001

# Twilio (the relay number that managers text)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# The FocusGate number managers send to (E.164, e.g. +14155550123)
FOCUSGATE_NUMBER=+1...

# Concierge v1: a single student behind the number.
# (Multi-student keying comes with Approach A; v1 tests one student at a time.)
STUDENT_NAME=Alex
STUDENT_PHONE=+1...

# Verify Twilio request signatures. Defaults to true in production.
# Set false ONLY for local dev where the public URL (ngrok) breaks signing.
VALIDATE_TWILIO_SIGNATURE=false
# Public base URL Twilio calls (needed for signature validation), e.g. https://abc.ngrok.io
PUBLIC_BASE_URL=
